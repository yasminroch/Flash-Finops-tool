# === Flash Analytics Backend - Environment Variables ===

# Gemini AI (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# JWT Auth
JWT_SECRET=change-this-to-a-random-string
JWT_EXPIRATION_HOURS=24

# Database (Render sets this automatically)
DATABASE_URL=postgresql://flash:flash123@postgres:5432/flash_analytics

# Data path
DATA_PATH=/app/data

# Default Users (JSON format — email as key, password/name/role as value)
DEFAULT_USERS={"admin@flash.com":{"password":"flash123","name":"Admin Flash","role":"admin"}}
